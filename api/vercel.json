{
  "builds": [
    {
      "src": "app/main.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "app/main.py"
    }
  ],
  "crons": [
    { "path": "/api/cron/overdue", "schedule": "0 2 * * *" },
    { "path": "/api/cron/expire-reservations", "schedule": "0 6 * * *" }
  ]
}
